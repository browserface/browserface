{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist/client",
    "rootDir": "src",
    "noEmit": true,
    "types": []
  },
  "include": ["src/client/**/*", "src/shared/**/*"]
}
